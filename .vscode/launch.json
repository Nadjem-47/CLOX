{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch clox",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/debug.exe", // Change to main.exe if needed
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe", // Path to your MSYS2 debugger
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: gcc.exe build active file" // Runs your build task first
        }
    ]
    }
